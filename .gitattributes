* text=auto

# Keep Unity YAML assets text/merge-friendly.
*.asmdef text eol=lf
*.asmref text eol=lf
*.asset text eol=lf
*.controller text eol=lf
*.anim text eol=lf
*.mat text eol=lf
*.meta text eol=lf
*.overrideController text eol=lf
*.playable text eol=lf
*.prefab text eol=lf
*.preset text eol=lf
*.renderTexture text eol=lf
*.shader text eol=lf
*.shadergraph text eol=lf
*.unity text eol=lf
*.uxml text eol=lf
*.uss text eol=lf
*.inputactions text eol=lf

# Source/config text.
*.cs text eol=lf
*.cginc text eol=lf
*.compute text eol=lf
*.hlsl text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

